App(
    appid="claude_buddy",
    name="Claude Buddy",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="claude_buddy_app",
    stack_size=4 * 1024,
    sources=["*.c"],
    fap_libs=["ble_profile"],
    fap_description="Anthropic Hardware Buddy bridge for Claude desktop",
    fap_version="0.4.3",
    fap_category="Bluetooth",
    # Phase 2: LE Secure Connections + MITM-protected bonding. Matches the
    # pairing flow the Claude desktop Hardware Buddy window expects
    # (DisplayOnly peripheral → 6-digit passkey shown on Flipper, typed on
    # desktop). Remove this line to rebuild Phase 1's unencrypted link for
    # diagnostics — the profile code branches on CLAUDE_BUDDY_ENCRYPTED.
    cdefines=["CLAUDE_BUDDY_ENCRYPTED"],
    # 10x10 1-bit silhouette of the Claude Code mascot (boxy terracotta
    # robot). Stylized to the Flipper's OLED constraints; preserved here
    # so future tweaks go through version control and the build pipeline
    # (scripts/flipper/assets/icon.py inverts + heatshrink-compresses).
    fap_icon="icons/claude_buddy_10px.png",
    # In-app icon assets. *.png files under this dir are compiled into the
    # FAP as addressable symbols — e.g. mascot_32x32.png → I_mascot_32x32
    # with the header exposed as <symbol>_icons.h. Animated icons become
    # subdirectories with frame_NN.png + a frame_rate text file (planned
    # for Phase 5 mascot state machine).
    fap_icon_assets="assets",
    fap_icon_assets_symbol="claude_buddy",
)
